<mujoco model="vortex mani test">

    <option integrator="implicitfast" impratio="10" cone="elliptic" noslip_iterations="2">
        <flag multiccd="enable"/>
    </option>
    <visual>
        <global azimuth="220" elevation="-30" offwidth="1280" offheight="960"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.6 0.7 0.8" rgb2="0.4 0.5 0.6" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"/>
        <model name="centrifuge_10slot" file="../object/centrifuge_10slot.gen.xml" content_type="text/xml" />
        <model name="table" file="../misc/simple_table.xml" content_type="text/xml" />
        <model name="aloha" file="../robot/aloha_left.xml" content_type="text/xml" />
        <model name="centrifuge_15ml_screw" file="../object/centrifuge_15ml_screw.xml" content_type="text/xml" />
        <model name="vortex_mixer_genie_2" file="../instrument/vortex_mixer_genie_2.xml" content_type="text/xml" />
    </asset>

    <worldbody>
        <light directional="true" diffuse="0.8 0.8 0.8" ambient="0.2 0.2 0.2" pos="0 0 5" dir="0 0 -1"/>
        <geom name="floor" pos="0 0 0" size="2.5 2 0.05" type="plane" material="groundplane"/>
        <body name="table" pos="0 0 0." quat="1 0 0 1">
            <camera name="table_cam_front" pos="0. -1.2 1.45" quat="0.819 0.574 0 0" fovy="45" resolution="1280 960"/>
            <attach model="table" body="vention table" prefix="1/"/>
            <body name="aloha1" pos="0.4 0.05 0.824" quat="0 0 0 1" >
                <attach model="aloha" body="left/base_link" prefix="1/aloha:"/>
            </body>
            <body name="aloha2" pos="-0.4 0.2 0.824" quat="1 0 0 0" >-0.45 -0.3 0.824
                <attach model="aloha" body="left/base_link" prefix="2/aloha:"/>
            </body>

            <body name="slot" pos="-0.05 -0.1 0.854" quat="-1 0 0 1">
                <attach model="centrifuge_10slot" body="centrifuge_10slot" prefix="/"/>
                <site name="origin1" pos="-0.09 0.036 -0.024" euler="0 0 -90" size="0.005" rgba="1 0 0 1" group="3"/>
                <site name="origin2" pos="-0.072 0.018 -0.024" euler="0 0 -90" size="0.005" rgba="1 0 0 1" group="3"/>
            </body>
        </body>
        <body name="centrifuge_15ml_screw_cap" pos="0 0 0.83" quat="-1 0 0 1">
            <joint name="centrifuge_15ml_cap" type="free"/>
            <attach model="centrifuge_15ml_screw" body="centrifuge_15ml_cap" prefix="2/"/>
        </body>
        <body name="centrifuge_15ml_screw_body" pos="0 0 0.83" quat="1 0 0 0">
            <joint name="centrifuge_15ml_body" type="free"/>
            <attach model="centrifuge_15ml_screw" body="centrifuge_15ml_body" prefix="1/"/>
            <site name="centrifuge_body" pos="0. 0. 0." euler="0 0 -90" size="0.03" rgba="1 0 0 1" group="5"/>

        </body>
        <body name="vortex_mixer_genie_2" pos="-0.2 -0.05 0.83" quat="1 0 0 0">0.3 0.15 0.83
            <attach model="vortex_mixer_genie_2" body="world" prefix="/vortex_mixer_genie_2:" />
        </body>
        <!-- <site name="example_pose" pos="0. 0. 0." size="0.03" rgba="1 0 0 1" group="5" /> -->
    </worldbody>
 
    
    <contact>
        <pair geom1="2/nut" geom2="1/bolt" friction="1" solref="0.002 1"/>
        <pair geom1="2/nut" geom2="1/body_cyl" friction="1" solref="0.002 1" solimp="0.9 0.95 0.001"/>
    </contact>
</mujoco>